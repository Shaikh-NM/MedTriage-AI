# ── LLM Provider (uncomment the one you use) ──────────────────────────────────
OPENAI_API_KEY=sk-...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ── Model Configuration ────────────────────────────────────────────────────────
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1000

# ── RAG Configuration ──────────────────────────────────────────────────────────
RAG_INDEX_PATH=rag/faiss_index
RAG_TOP_K=3

# ── Monitoring (LangSmith) ─────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=medtriage-ai

# ── UI ─────────────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── Safety ─────────────────────────────────────────────────────────────────────
ESCALATION_BIAS=true
